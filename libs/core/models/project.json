{
  "name": "core-models",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/core/models/src",
  "projectType": "library",
  "tags": ["core", "core:models"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/core/models",
        "main": "libs/core/models/src/index.ts",
        "tsConfig": "libs/core/models/tsconfig.lib.json",
        "assets": ["libs/core/models/*.md"]
      }
    }
  }
}
